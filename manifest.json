{
  "manifest_version": 3,
  "name": "AsciiTab",
  "version": "1.0.0",
  "description": "A keyboard-centric browser startpage with ASCII aesthetics and Catppuccin theming",
  "icons": {
    "48": "icon48.png",
    "96": "icon96.png",
    "128": "icon128.png"
  },
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "permissions": [
    "storage"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "asciitab@siddestech.com",
      "strict_min_version": "109.0"
    }
  }
}
