{
  "manifest_version": 3,
  "name": "AsciiTab",
  "version": "4.0.0",
  "description": "A keyboard-centric browser startpage with ASCII aesthetics and Catppuccin theming",
  "icons": {
    "48": "AsciiTab.png",
    "128": "AsciiTab.png"
  },
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "permissions": [
    "storage"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "asciitab@siddestech.com",
      "strict_min_version": "142.0"
    }
  }
}