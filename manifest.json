{
  "manifest_version": 3,
  "name": "Catppuccin Startpage",
  "version": "1.0",
  "description": "A beautiful, customizable Catppuccin-themed startpage.",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "permissions": [
    "storage"
  ],
  "action": {
    "default_title": "Catppuccin Startpage"
  },
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "asciitab@siddestech.com",
      "strict_min_version": "135.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}
